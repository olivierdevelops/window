suite "Password strength reacts to input"
use ./password_strength.capyx

scenario "classifies strength as you type"
    mount password_strength
    expect text "Enter a password"
    input .pw "abc"
    expect text "Weak"
    input .pw "abcdefg"
    expect text "Fair"
    input .pw "abcdefghijkl"
    expect text "Strong"
